{
  "name": "@background-agents/agent-configuration",
  "version": "0.1.0",
  "description": "Translation layer between coding agents' configuration formats",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./permissions": {
      "import": {
        "types": "./dist/permissions/index.d.ts",
        "default": "./dist/permissions/index.js"
      },
      "require": {
        "types": "./dist/permissions/index.d.cts",
        "default": "./dist/permissions/index.cjs"
      }
    },
    "./mcp": {
      "import": {
        "types": "./dist/mcp/index.d.ts",
        "default": "./dist/mcp/index.js"
      },
      "require": {
        "types": "./dist/mcp/index.d.cts",
        "default": "./dist/mcp/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/permissions/index.ts src/mcp/index.ts --format esm,cjs --dts --clean --sourcemap",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "agent",
    "configuration",
    "mcp",
    "permissions",
    "translation"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "@daytonaio/sdk": "^0.170.0"
  },
  "peerDependenciesMeta": {
    "@daytonaio/sdk": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
