# =============================================================================
# Test-mode env — copy to packages/web/.env.test.
#
# Defines what makes "test mode" different from dev: a separate test DB,
# the /api/test/auth route enabled, placeholder OAuth, and a fixed
# NextAuth secret. Loaded by:
#   - playwright.config.ts (for `npm run test:e2e`)
#   - the root `dev:test` script (for running a dev server in test mode)
#
# Shared secrets (DAYTONA_API_KEY, etc.) cascade in from root .env.local —
# this file only contains what's different in test mode.
#
# IMPORTANT: Use a SEPARATE test database, NOT your production database.
# Tests run `prisma migrate reset --force` before every run.
# =============================================================================

# Test Database (REQUIRED)
# The URL MUST contain 'localhost' or '127.0.0.1' as a safety check.
# Set I_KNOW_THIS_IS_THE_TEST_DB=true to bypass.
DATABASE_URL="postgresql://user:password@localhost:5432/sandboxed_agents_test"

# Enable the /api/test/auth route (lets Playwright and dev:test create
# test sessions without going through real GitHub OAuth)
ENABLE_TEST_AUTH=true

# NextAuth — fixed values for test mode
NEXTAUTH_SECRET=test-secret-for-e2e-tests
NEXTAUTH_URL=http://localhost:4000

# GitHub OAuth — placeholders since test auth bypasses real OAuth
GITHUB_CLIENT_ID=placeholder
GITHUB_CLIENT_SECRET=placeholder
