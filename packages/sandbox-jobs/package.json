{
  "name": "@background-agents/sandbox-jobs",
  "version": "0.1.0",
  "description": "Run, observe, and reconnect to long-running shell processes in a Daytona sandbox via the filesystem. Byte-offset incremental reads, real exit codes, and cold-reconnect-by-id.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@daytonaio/sdk": ">=0.8.0"
  },
  "devDependencies": {
    "@daytonaio/sdk": "^0.170.0",
    "@types/node": "^20.10.0",
    "dotenv": "^17.3.1",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "daytona",
    "sandbox",
    "background",
    "process",
    "long-running"
  ],
  "license": "MIT"
}
