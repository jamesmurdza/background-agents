{
  "name": "@background-agents/sandbox-terminal",
  "version": "0.2.0",
  "description": "WebSocket-based PTY terminal for Daytona sandboxes",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "default": "./dist/components/index.js"
    },
    "./sandbox": {
      "types": "./dist/sandbox/index.d.ts",
      "default": "./dist/sandbox/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc && tsc-alias --resolve-full-paths",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run tests/integration",
    "prepare": "npm run build"
  },
  "dependencies": {
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0"
  },
  "devDependencies": {
    "@daytonaio/sdk": "^0.170.0",
    "@types/node": "^20.10.0",
    "@types/react": "^19",
    "@types/ws": "^8.5.10",
    "dotenv": "^17.3.1",
    "react": "^19.2.4",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "@daytonaio/sdk": ">=0.170.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@daytonaio/sdk": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
